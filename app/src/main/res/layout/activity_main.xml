<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nadi_mist"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:id="@+id/homePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_deep_panel"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip"
                    android:text="@string/nadi_tagline"
                    android:textColor="@color/nadi_deep_green"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/app_name"
                    android:textColor="@color/white"
                    android:textSize="44sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/home_intro"
                    android:textColor="@color/nadi_line"
                    android:textSize="16sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/createRoomButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:text="@string/start_room"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:backgroundTint="@color/nadi_green"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/joinRoomButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="@string/join_room"
                android:textAllCaps="false"
                android:textColor="@color/nadi_green"
                app:cornerRadius="10dp"
                app:strokeColor="@color/nadi_line" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_outline_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/recent_transfers"
                    android:textColor="@color/nadi_graphite"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/recentEmptyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/recent_empty"
                    android:textColor="@color/nadi_soft_ink"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/historyPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/history_title"
                android:textColor="@color/nadi_graphite"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:text="@string/history_copy"
                android:textColor="@color/nadi_soft_ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/historyListText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_outline_card"
                android:lineSpacingExtra="3dp"
                android:padding="18dp"
                android:text="@string/history_empty"
                android:textColor="@color/nadi_soft_ink"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clearHistoryButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:text="@string/clear_history"
                android:textAllCaps="false"
                android:textColor="@color/nadi_error"
                app:cornerRadius="10dp"
                app:strokeColor="@color/nadi_error" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/historyBackButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:text="@string/back_home"
                android:textAllCaps="false"
                android:textColor="@color/nadi_soft_ink" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/setupPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/host_setup_title"
                android:textColor="@color/nadi_graphite"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:text="@string/host_setup_copy"
                android:textColor="@color/nadi_soft_ink"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_outline_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/room_name_label"
                    android:textColor="@color/nadi_graphite"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/roomNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/nadi_green"
                    android:inputType="textCapWords"
                    android:singleLine="true"
                    android:text="@string/room_name_default"
                    android:textColor="@color/nadi_graphite"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/host_name_label"
                    android:textColor="@color/nadi_graphite"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/hostNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/nadi_green"
                    android:inputType="textCapWords"
                    android:singleLine="true"
                    android:text="@string/host_name_default"
                    android:textColor="@color/nadi_graphite"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_outline_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/network_mode_label"
                    android:textColor="@color/nadi_graphite"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/networkModeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/sameWifiModeRadio"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="@string/same_wifi_mode"
                        android:textColor="@color/nadi_graphite" />

                    <RadioButton
                        android:id="@+id/hotspotModeRadio"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/hotspot_mode"
                        android:textColor="@color/nadi_graphite" />
                </RadioGroup>

                <TextView
                    android:id="@+id/networkModeHelpText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/same_wifi_note"
                    android:textColor="@color/nadi_soft_ink"
                    android:textSize="14sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/startLocalRoomButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:text="@string/start_local_room"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:backgroundTint="@color/nadi_green"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/setupBackButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:text="@string/back_home"
                android:textAllCaps="false"
                android:textColor="@color/nadi_soft_ink" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/activeRoomPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_deep_panel"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:id="@+id/activeStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip"
                    android:text="@string/room_active"
                    android:textColor="@color/nadi_deep_green"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/activeRoomNameText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/room_name_default"
                    android:textColor="@color/white"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/activeRoomCopyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/same_wifi_note"
                    android:textColor="@color/nadi_line"
                    android:textSize="15sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/qrImage"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:background="@color/white"
                android:contentDescription="@string/copy_url"
                android:padding="10dp" />

            <TextView
                android:id="@+id/joinUrlText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_outline_card"
                android:padding="14dp"
                android:textColor="@color/nadi_green"
                android:textIsSelectable="true"
                android:textSize="13sp"
                tools:text="http://192.168.1.2:8080/?token=abc" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/copyUrlButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="@string/copy_url"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/nadi_green"
                    app:cornerRadius="10dp" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/regenerateLinkButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="@string/regenerate_link"
                    android:textAllCaps="false"
                    android:textColor="@color/nadi_green"
                    app:cornerRadius="10dp"
                    app:strokeColor="@color/nadi_green" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/stopRoomButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="@string/stop_room"
                android:textAllCaps="false"
                android:textColor="@color/nadi_error"
                app:cornerRadius="10dp"
                app:strokeColor="@color/nadi_error" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_outline_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/room_privacy_title"
                    android:textColor="@color/nadi_graphite"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/privacyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/room_privacy_copy"
                    android:textColor="@color/nadi_soft_ink"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_outline_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/connected_devices_title"
                    android:textColor="@color/nadi_graphite"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/clientListText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/connected_devices_empty"
                    android:textColor="@color/nadi_soft_ink"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_outline_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/host_shared_files_title"
                    android:textColor="@color/nadi_graphite"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/addSharedFileButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/add_shared_file"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/nadi_green"
                    app:cornerRadius="10dp" />

                <TextView
                    android:id="@+id/sharedFilesText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/shared_files_empty"
                    android:textColor="@color/nadi_soft_ink" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_outline_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/host_received_files_title"
                    android:textColor="@color/nadi_graphite"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/receivedFilesText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/received_files_empty"
                    android:textColor="@color/nadi_soft_ink" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_outline_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/host_chat_title"
                    android:textColor="@color/nadi_graphite"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chatMessagesText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/chat_empty"
                    android:textColor="@color/nadi_soft_ink" />

                <EditText
                    android:id="@+id/hostChatInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/nadi_green"
                    android:hint="@string/host_chat_hint"
                    android:inputType="textCapSentences"
                    android:singleLine="true"
                    android:textColor="@color/nadi_graphite"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sendHostMessageButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/send_message"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/nadi_green"
                    app:cornerRadius="10dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_outline_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/diagnostics_title"
                    android:textColor="@color/nadi_graphite"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/diagnosticsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/diagnostics_empty"
                    android:textColor="@color/nadi_soft_ink"
                    android:textIsSelectable="true"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/copyDiagnosticsButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/copy_diagnostics"
                    android:textAllCaps="false"
                    android:textColor="@color/nadi_green"
                    app:cornerRadius="10dp"
                    app:strokeColor="@color/nadi_green" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
